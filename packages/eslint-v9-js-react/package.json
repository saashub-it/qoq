{
  "name": "@saashub/qoq-eslint-v9-js-react",
  "version": "3.2.4",
  "description": "Eslint flat config template for JS + React",
  "keywords": [
    "eslint JavaScript + React template",
    "flat config",
    "saashub",
    "qoq",
    "QualityOverQuantity"
  ],
  "homepage": "https://github.com/saashub-it/qoq/tree/master/packages/eslint-v9-js-react",
  "bugs": {
    "url": "https://github.com/saashub-it/qoq/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/saashub-it/qoq.git",
    "directory": "packages/eslint-v9-js-react"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.mjs",
      "require": "./lib/index.cjs"
    }
  },
  "main": "./lib/index.cjs",
  "module": "./lib/index.mjs",
  "types": "./lib/index.d.ts",
  "bin": {
    "@saashub/qoq-eslint-v9-js-react": "./bin/bin.js"
  },
  "files": [
    "bin",
    "lib",
    "eslint.config.local.js"
  ],
  "scripts": {
    "build": "rimraf ./lib && rollup -c rollup.config.js --silent && rimraf ./bin && rollup -c rollup.bin.js --silent",
    "inspect": "node ./bin/bin.cjs"
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "5.7.9",
    "@saashub/qoq-eslint-v9-js": "^3.2.4",
    "@saashub/qoq-utils": "^3.2.4",
    "@stylistic/eslint-plugin": "5.10.0",
    "browserslist": "latest",
    "eslint-plugin-compat": "7.0.2"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "12.3.0",
    "rimraf": "6.1.3",
    "rollup": "4.60.4",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "eslint": "^10.3.0"
  },
  "engines": {
    "node": ">=22.13.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "gitHead": "4c369fd421f71f58eb1d8467eaa02d85d2f09263"
}
