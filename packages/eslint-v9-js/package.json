{
  "name": "@saashub/qoq-eslint-v9-js",
  "version": "2.2.0",
  "description": "Eslint flat config template for JS",
  "keywords": [
    "eslint JavaScript template",
    "flat config",
    "saashub",
    "qoq",
    "QualityOverQuantity"
  ],
  "homepage": "https://github.com/saashub-it/qoq/tree/master/packages/eslint-v9-js",
  "bugs": {
    "url": "https://github.com/saashub-it/qoq/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/saashub-it/qoq.git",
    "directory": "packages/eslint-v9-js"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "module": "./lib/index.mjs",
      "import": "./lib/index.mjs",
      "require": "./lib/index.cjs",
      "default": "./lib/index.mjs"
    },
    "./tools": {
      "types": "./lib/tools.d.ts",
      "module": "./lib/tools.mjs",
      "import": "./lib/tools.mjs",
      "require": "./lib/tools.cjs",
      "default": "./lib/tools.mjs"
    }
  },
  "main": "./lib/index.cjs",
  "module": "./lib/index.mjs",
  "types": "./lib/index.d.ts",
  "bin": {
    "@saashub/qoq-eslint-v9-js": "./bin/bin.js"
  },
  "files": [
    "bin",
    "lib",
    "eslint.config.local.js"
  ],
  "scripts": {
    "build": "rimraf ./lib && rollup -c rollup.config.js --silent && rimraf ./bin && rollup -c rollup.bin.js --silent",
    "inspect": "node ./bin/bin.cjs"
  },
  "dependencies": {
    "@eslint/js": "^9.39.2",
    "@saashub/qoq-utils": "^2.2.0",
    "eslint": "^9.39.2",
    "eslint-plugin-import-x": "4.16.1",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-sonarjs": "4.0.1",
    "globals": "17.4.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-terser": "1.0.0",
    "@rollup/plugin-typescript": "12.3.0",
    "rimraf": "6.1.3",
    "rollup": "4.59.0",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "eslint": "^9.39.2"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "gitHead": "4c369fd421f71f58eb1d8467eaa02d85d2f09263"
}
